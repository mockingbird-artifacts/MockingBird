            "        DisjointSetNode<E> e1Root = find0(getNode(e1));",
            "        DisjointSetNode<E> e2Root = find0(getNode(e2));",
            "",
            "        if (e1Root == e2Root) {",
            "            return;",
            "        }",
            "",
            "        int comparison = e1Root.compareTo(e2Root);",
            "        if (comparison < 0) {",
            "            e1Root.setParent(e2Root);",
            "        } else if (comparison > 0) {",
            "            e2Root.setParent(e1Root);",
            "        } else {",
            "            e2Root.setParent(e1Root);",
            "            e1Root.increaseRank();",
            "        }",
