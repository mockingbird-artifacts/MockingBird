            "    public void testLanguageGuessing() {",
            "        final Languages.LanguageSet guesses = this.lang.guessLanguages(this.name);",
            "",
            "        assertTrue(",
            "                \"language predicted for name '\"",
            "                        + this.name",
            "                        + \"' is wrong: \"",
            "                        + guesses",
            "                        + \" should contain '\"",
            "                        + this.language",
            "                        + \"'\",",
            "                guesses.contains(this.language));",
            "    }"
