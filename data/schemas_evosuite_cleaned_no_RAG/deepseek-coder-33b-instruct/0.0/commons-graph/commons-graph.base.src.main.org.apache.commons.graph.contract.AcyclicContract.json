          "end": 52,
          "body": [
            "public CycleDetector(DirectedGraph<V, E> graph) {",
            "            this.dfs = new DFS();",
            "            this.graph = graph;",
            "            Iterator<V> verts = graph.getVertices().iterator();",
            "",
            "            if (verts.hasNext()) {",
            "                dfs.visit(graph, verts.next(), this);",
            "            }",
            "        }"
