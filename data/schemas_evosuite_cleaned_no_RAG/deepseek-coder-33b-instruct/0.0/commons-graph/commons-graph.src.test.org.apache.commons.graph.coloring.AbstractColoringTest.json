            "protected <V, E, C> void checkColoring(",
            "            UndirectedMutableGraph<V, E> g, ColoredVertices<V, C> coloredVertices) {",
            "        for (E e : g.getEdges()) {",
            "            VertexPair<V> vp = g.getVertices1(e);",
            "            C h = coloredVertices.getColor(vp.getHead());",
            "            C t = coloredVertices.getColor(vp.getTail());",
            "",
            "            assertNotNull(h);",
            "            assertNotNull(t);",
            "            assertTrue(!h.equals(t));",
            "        }",
            "    }"
          ],
