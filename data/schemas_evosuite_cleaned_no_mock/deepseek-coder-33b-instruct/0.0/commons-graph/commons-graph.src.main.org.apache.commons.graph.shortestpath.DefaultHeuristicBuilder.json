            "        hScore = heuristic.applyHeuristic(self.__start, self.__goal)",
            "        fScores.setWeight(self.__start, hScore)",
            "        ",
            "        closedSet = set()",
            "        ",
            "        openSet = FibonacciHeap(fScores)",
