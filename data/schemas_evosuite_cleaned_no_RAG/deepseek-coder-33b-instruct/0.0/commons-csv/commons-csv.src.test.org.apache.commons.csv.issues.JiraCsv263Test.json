          "translation": [
            "    def testPrintFromReaderWithQuotes(self):",
            "        from src.main.org.apache.commons.csv.CSVFormat import CSVFormat",
            "        from src.main.org.apache.commons.csv.CSVFormat import Builder",
            "        format = CSVFormat.DEFAULT.builder().setDelimiter('\\t').build()",
            "        out = StringIO()",
            "        Builder().print2(\"value\", out, True)",
            "        self.assertEqual(\"\\u001Evalue\\n\", out.getvalue())",
            "        ",
            "        out = StringIO()",
            "        Builder().print2(\"\\\"value\\\"\", out, True)",
            "        self.assertEqual(\"\\\"value\\\"\\n\", out.getvalue())",
            "        ",
            "        out = StringIO()",
            "        Builder().print2(\"\\\"val\\\\\\\"ue\\\"\", out, True)",
            "        self.assertEqual(\"\\\"val\\\\\\\"ue\\\"\\n\", out.getvalue())",
            "        ",
            "        out = StringIO()",
            "        Builder().print2(\"\\\"va\\tlu\\re\\\"\", out, True)",
            "        self.assertEqual(\"\\\"va\\tlu\\re\\\"\\n\", out.getvalue())",
            "        ",
            "        out = StringIO()",
            "        Builder().print2(\"\\\"val\\\\u001Eue\\\"\", out, True)",
            "        self.assertEqual(\"\\\"val\\\\u001Eue\\\"\\n\", out.getvalue())",
            "        ",
            "        out = StringIO()",
            "        Builder().print2(\"\\\"va\\tlu\\re\\t\\\"\", out, True)",
            "        self.assertEqual(\"\\\"va\\tlu\\re\\t\\\"\\n\", out.getvalue())"
          ],
