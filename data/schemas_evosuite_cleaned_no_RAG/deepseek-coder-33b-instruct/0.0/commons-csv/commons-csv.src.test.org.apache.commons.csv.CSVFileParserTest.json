            "    def testCSVFile(self, testFile: Path) -> None:",
            "        with open(testFile, 'r') as file:",
            "            lines = file.readlines()",
            "        ",
            "        for line in lines:",
            "            if not line.strip():",
            "                continue",
            "                ",
            "            fields = line.split(',')",
            "            ",
            "            self.assertEqual(len(fields), 3, \"Expected three fields per line\")",
            "            ",
            "            field1 = fields[0].strip()",
            "            field2 = fields[1].strip()",
            "            field3 = fields[2].strip()",
            "            ",
            "            self.assertTrue(field1.isdigit(), f\"Field 1 is not a digit: {field1}\")",
            "            self.assertTrue(field2.replace('.', '', 1).isdigit(), f\"Field 2 is not a decimal number: {field2}\")",
            "            ",
            "            if field3.lower() != \"true\":",
            "                self.fail(f\"Field 3 is not 'true': {field3}\")"
          ],
