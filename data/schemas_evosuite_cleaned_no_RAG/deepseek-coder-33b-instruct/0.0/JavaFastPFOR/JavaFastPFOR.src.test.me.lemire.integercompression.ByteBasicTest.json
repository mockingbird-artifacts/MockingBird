            "@Test",
            "    public void varyingLengthTest2() {",
            "        int N = 128;",
            "        int[] data = new int[N];",
            "        data[127] = -1;",
            "        for (ByteIntegerCODEC c : codecs) {",
            "            try {",
            "                // CODEC Simple9 is limited to \"small\" integers.",
            "                if (c.getClass().equals(",
            "                        Class.forName(\"me.lemire.integercompression.Simple9\")))",
            "                    continue;",
            "            } catch (ClassNotFoundException e) {",
            "                e.printStackTrace();",
            "            }",
            "            for (int L = 1; L <= 128; L++) {",
            "                byte[] comp = UtilsTest.compress0(c, Arrays.copyOf(data, L));",
            "                int[] answer = UtilsTest.uncompress1(c, comp, L);",
            "                for (int k = 0; k < L; ++k)",
            "                    if (answer[k] != data[k])",
            "                        throw new RuntimeException(\"bug at k = \"+k+\" \"+answer[k]+\" \"+data[k]);",
            "            }",
            "            for (int L = 128; L <= N; L *= 2) {",
            "                byte[] comp = UtilsTest.compress0(c, Arrays.copyOf(data, L));",
            "                int[] answer = UtilsTest.uncompress1(c, comp, L);",
            "                for (int k = 0; k < L; ++k)",
            "                    if (answer[k] != data[k])",
            "                        throw new RuntimeException(\"bug\");",
            "            }",
            "",
            "        }",
            "    }"
