          "translation": [
            "    @staticmethod",
            "    def newThread(threadFactory: ThreadPoolExecutor, runnable: Callable[[], None], prefix: str, daemon: bool) -> ThreadPoolExecutor:",
            "        thread = threadFactory.submit(runnable)",
            "        if thread is None:",
            "            raise Exception(f\"The ThreadFactory {threadFactory} could not construct a thread for '{prefix}'\")",
            "        thread_name = prefix + str(thread.result().ident)",
            "        thread._set_daemon(daemon)",
            "        return thread_name"
          ],
