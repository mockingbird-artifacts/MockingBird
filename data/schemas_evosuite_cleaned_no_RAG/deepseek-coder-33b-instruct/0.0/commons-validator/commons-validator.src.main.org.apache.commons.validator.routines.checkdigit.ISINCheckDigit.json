            "    def _calculateModulus(self, code: str, includesCheckDigit: bool) -> int:",
            "        transformed = StringIO()",
            "        if includesCheckDigit:",
            "            transformed.append(code[-1])",
            "        for i in range(len(code)-1):",
            "            char_value = ord(code[i]) - 48",
            "            if char_value > 9:",
            "                char_value -= 7",
            "            transformed.write(str(char_value))",
            "        ",
            "        modulus = 0",
            "        for i in range(len(transformed.getvalue())):",
            "            modulus = (modulus + int(transformed.getvalue()[i])) % self.__modulus",
            "        ",
            "        return modulus"
          ],
