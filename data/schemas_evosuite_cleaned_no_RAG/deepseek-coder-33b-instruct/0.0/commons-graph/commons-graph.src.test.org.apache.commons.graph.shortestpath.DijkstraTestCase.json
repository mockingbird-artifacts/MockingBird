            "    def testFindShortestPathAndVerify(self) -> None:",
            "        from src.main.org.apache.commons.graph.weight.primitive.DoubleWeightBaseOperations import DoubleWeightBaseOperations",
            "        from src.main.org.apache.commons.graph.CommonsGraph import CommonsGraph",
            "        from src.test.org.apache.commons.graph.model.BaseLabeledVertex import BaseLabeledVertex",
            "        from src.main.org.apache.commons.graph.model.InMemoryWeightedPath import InMemoryWeightedPath",
            "        from src.test.org.apache.commons.graph.model.BaseWeightedEdge import BaseWeightedEdge",
            "        graph = {",
            "                    \"1\": {\"6\": 14, \"3\": 9, \"2\": 7},",
            "                    \"2\": {\"3\": 10, \"4\": 15},",
            "                    \"3\": {\"6\": 2, \"4\": 11},",
            "                    \"4\": {\"5\": 6},",
            "                    \"6\": {\"5\": 9}",
            "                }",
            "        ",
            "        expected = InMemoryWeightedPath(",
            "            start=\"1\",",
            "            target=\"5\",",
            "            weightOperations=DoubleWeightBaseOperations(),",
            "            weightedEdges=BaseLabeledVertex(\"1\")",
            "        )",
            "        ",
            "        expected.addConnectionInTail(\"1\", (\"1 -> 3\", 9), \"3\")",
            "        expected.addConnectionInTail(\"3\", (\"3 -> 6\", 2), \"6\")",
            "        expected.addConnectionInTail(\"6\", (\"6 -> 5\", 9), \"5\")",
            "        ",
            "        actual = CommonsGraph.findShortestPath(graph) \\",
            "            .whereEdgesHaveWeights(BaseWeightedEdge()) \\",
            "            .from_(\"1\") \\",
            "            .to(\"5\") \\",
            "            .applyingDijkstra(DoubleWeightBaseOperations())",
            "        ",
            "        self.assertEqual(expected, actual)"
