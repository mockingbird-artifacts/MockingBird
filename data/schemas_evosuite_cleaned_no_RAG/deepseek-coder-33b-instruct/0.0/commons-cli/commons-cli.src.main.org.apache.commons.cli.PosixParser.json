            "                    ",
            "                    self.__tokens.append(\"-\" + ch)",
            "                    self.__currentOption = self.__options.getOption(ch)",
            "        ",
            "                    if self.__currentOption.hasArg() and len(token) != i + 1:",
            "                        self.__tokens.append(token[i+1:])",
            "                        break"
