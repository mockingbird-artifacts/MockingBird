            "public WE getMinimumWeightEdge() {",
            "        boolean found = false;",
            "        WE edge = null;",
            "        while (!found && !orderedEdges.isEmpty()) {",
            "            edge = orderedEdges.pollFirst();",
            "            VertexPair<V> pair = graph.getVertices1(edge);",
            "            if (!vertices.contains(pair.getHead()) || !vertices.contains(pair.getTail())) {",
            "                found = true;",
            "            }",
            "        }",
            "        return edge;",
            "    }"
          ],
