          "translation": [
            "    def __createCommandFile(self, cmd: object, env: object) -> Path:",
            "        from pathlib import Path",
            "        from io import StringIO",
            "        import subprocess",
            "        import os",
            "",
            "        path = Path.cwd() / \"EXEC.TMP\"",
            "        script = path.to_file()",
            "        try:",
            "            with open(path, 'w') as writer:",
            "                if env is not None:",
            "                    for key, value in env.items():",
            "                        writer.write(\"$ {} == \".format(key))",
            "                        if value.find('\"') > -1:",
            "                            value = value.replace('\"', '\"\"')",
            "                        writer.write('\"{}\"\\n'.format(value))",
            "                for line in cmd:",
            "                    writer.write(line + \"\\n\")",
            "        except Exception as e:",
            "            print(\"Error writing to file: \", str(e))",
            "        ",
            "        return script"
          ],
