          "translation": [
            "    @staticmethod",
            "    def regionMatches(cs: Union[AnyStr, str], ignoreCase: bool, thisStart: int, substring: Union[AnyStr, str], start: int, length: int) -> bool:",
            "        if isinstance(cs, str) and isinstance(substring, str):",
            "            return cs.lower()[thisStart:thisStart+length] == substring.lower()[start:start+length] if ignoreCase else cs[thisStart:thisStart+length] == substring[start:start+length]",
            "        ",
            "        index1 = thisStart",
            "        index2 = start",
            "        tmpLen = length",
            "",
            "        while tmpLen > 0:",
            "            c1 = cs[index1]",
            "            c2 = substring[index2]",
            "            ",
            "            if ignoreCase:",
            "                c1 = c1.lower()",
            "                c2 = c2.lower()",
            "                ",
            "            if c1 != c2:",
            "                return False",
            "            ",
            "            index1 += 1",
            "            index2 += 1",
            "            tmpLen -= 1",
            "        ",
            "        return True"
          ],
