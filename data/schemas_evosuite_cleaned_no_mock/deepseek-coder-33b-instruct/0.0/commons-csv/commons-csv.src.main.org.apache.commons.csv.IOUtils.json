            "            throws IOException {",
            "        long count = 0;",
            "        int n;",
            "        while (EOF != (n = input.read(buffer))) {",
            "            ((Buffer) buffer).flip();",
            "            output.append(buffer, 0, n);",
            "            count += n;",
            "        }",
            "        return count;",
            "    }"
