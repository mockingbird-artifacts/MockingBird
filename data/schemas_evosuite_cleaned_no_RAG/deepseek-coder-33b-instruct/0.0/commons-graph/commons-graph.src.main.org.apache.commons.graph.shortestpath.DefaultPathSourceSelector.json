            "    def applyingFloydWarshall(self, weightOperations: object) -> AllVertexPairsShortestPath:",
            "        from src.main.org.apache.commons.graph.shortestpath.AllVertexPairsShortestPath import AllVertexPairsShortestPath",
            "        from src.main.org.apache.commons.graph.WeightedPath import WeightedPath",
            "        from src.main.org.apache.commons.graph.shortestpath.PredecessorsList import PredecessorsList",
            "        from org.apache.commons.graph.shortestpath import PredecessorsList",
            "        from org.apache.commons.graph.shortestpath import WeightedPath",
            "        ",
            "        nextVertices = self.__graph.getNextVertices()",
            "        distances = {}",
            "        predecessors = {}",
            "        ",
            "        for vertex in self.__graph.getVertices():",
            "            distances[vertex] = {}",
            "            predecessors[vertex] = {}",
            "            ",
            "            for nextVertex in nextVertices:",
            "                if nextVertex == vertex:",
            "                    distances[vertex][nextVertex] = 0",
            "                elif self.__weightedEdges[(vertex, nextVertex)] is not None:",
            "                    distances[vertex][nextVertex] = self.__weightedEdges[(vertex, nextVertex)]",
            "                else:",
            "                    distances[vertex][nextVertex] = float('inf')",
            "                    ",
            "        for k in self.__graph.getVertices():",
            "            for i in self.__graph.getVertices():",
            "                for j in self.__graph.getVertices():",
            "                    if distances[i][j] > distances[i][k] + distances[k][j]:",
            "                        distances[i][j] = distances[i][k] + distances[k][j]",
            "                        predecessors[i][j] = k",
            "        ",
            "        return AllVertexPairsShortestPath(distances, PredecessorsList(predecessors), WeightedPath())"
