          "translation": [
            "    @staticmethod",
            "    def checkFileName(fileName: str) -> str:",
            "        from src.main.org.apache.commons.fileupload.InvalidFileNameException import InvalidFileNameException",
            "        if fileName is not None and '\\u0000' in fileName:",
            "            sb = StringIO()",
            "            for i in range(len(fileName)):",
            "                c = fileName[i]",
            "                if ord(c) == 0:",
            "                    sb.write(\"\\\\0\")",
            "                else:",
            "                    sb.write(c)",
            "            raise InvalidFileNameException(fileName, \"Invalid file name: \" + sb.getvalue())",
            "        return fileName"
          ],
