          "body": [
            "public static void handleException(final String msg, final Exception e) {",
            "        if (isDebugEnabled()) {",
            "            System.err.println(msg);",
            "            e.printStackTrace();",
            "        }",
            "        if (!isLenientEnabled()) {",
            "            if (e instanceof RuntimeException) {",
            "                throw (RuntimeException) e;",
            "            }",
            "            throw new RuntimeException(e);",
            "        }",
            "    }"
          ],
