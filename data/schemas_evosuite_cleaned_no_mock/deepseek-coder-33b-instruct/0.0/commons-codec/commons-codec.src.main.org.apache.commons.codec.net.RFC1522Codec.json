            "        }",
            "        from = to + 1;",
            "        to = text.indexOf(SEP, from);",
            "        byte[] data = StringUtils.getBytesUsAscii(text.substring(from, to));",
            "        data = doDecoding(data);",
            "        return new String(data, charset);",
            "    }"
