            "        final StringBuilder saltString = new StringBuilder(num);",
            "        for (int i = 1; i <= num; i++) {",
            "            saltString.append(B64T_STRING.charAt(random.nextInt(B64T_STRING.length())));",
            "        }",
            "        return saltString.toString();",
            "    }"
