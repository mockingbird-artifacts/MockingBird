            "    def caverphone(self, source: object) -> str:",
            "        if not source or isinstance(source, bool):",
            "            return self.__encoder.encode(source)",
            "        ",
            "        s = str(source).lower()",
            "        s = re.sub('[^a-z]', '', s)",
            "        s = s.replace(\"c\", \"s\").replace(\"g\", \"j\") \\",
            "             .replace(\"j\", \"g\").replace(\"s\", \"z\") \\",
            "             .replace(\"t\", \"d\").replace(\"v\", \"f\")",
            "        ",
            "        s = re.sub('([aeiou])', r'0\\1', s)",
            "        s = re.sub('([bcdfhj-np-tv-xz])', r'\\11', s)",
            "        s = re.sub(r'(^|[hw])([a-z])\\\\2', '', s)",
            "        ",
            "        s = re.sub('0', '1', s)",
            "        s = re.sub('([aeiou])y([bcdfghj-np-tvxz])', r'\\1\\2', s)",
            "        s = re.sub(r'^([pn]|[tskp])(\\1*)', '', s)",
            "        ",
            "        s = re.sub('(.)\\\\1+', '\\\\1', s)",
            "        s = re.sub('0', '', s)",
            "        s = re.sub('^c', '', s)",
            "        ",
            "        return (s + self.__encoder.__TEN_1)[:len(self.__encoder.__TEN_1)]"
          ],
