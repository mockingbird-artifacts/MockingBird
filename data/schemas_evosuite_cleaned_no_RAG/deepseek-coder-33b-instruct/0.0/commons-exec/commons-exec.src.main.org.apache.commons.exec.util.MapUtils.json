            "public static <K, V> Map<K, V> merge(final Map<K, V> lhs, final Map<K, V> rhs) {",
            "        Map<K, V> result = null;",
            "        if (lhs == null || lhs.isEmpty()) {",
            "            result = copy(rhs);",
            "        } else if (rhs == null || rhs.isEmpty()) {",
            "            result = copy(lhs);",
            "        } else {",
            "            result = copy(lhs);",
            "            result.putAll(rhs);",
            "        }",
            "        return result;",
            "    }"
