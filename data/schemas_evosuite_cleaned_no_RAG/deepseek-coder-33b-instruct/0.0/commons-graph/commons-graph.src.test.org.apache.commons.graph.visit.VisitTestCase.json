            "        UndirectedMutableGraph<BaseLabeledVertex, BaseLabeledEdge> input =",
            "                newUndirectedMutableGraph(",
            "                        new AbstractGraphConnection<BaseLabeledVertex, BaseLabeledEdge>() {",
            "",
            "                            public void connect0() {",
