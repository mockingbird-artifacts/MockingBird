            "        V k = next.get(new VertexPair<V>(source, target));",
            "        if (k == null) {",
            "            WE edge = graph.getEdge(source, target);",
            "            if (edge != null) {",
            "                path.addPredecessor(target, source);",
            "            }",
            "        } else {",
            "            pathReconstruction(path, source, k, next);",
            "            pathReconstruction(path, k, target, next);",
            "        }",
            "    }"
