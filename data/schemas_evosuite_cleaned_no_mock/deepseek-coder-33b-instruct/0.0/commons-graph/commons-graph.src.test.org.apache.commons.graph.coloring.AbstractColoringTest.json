            "protected Map<Integer, String> createColorMap(int numColor) {",
            "        Map<Integer, String> colorCodes = new HashMap<Integer, String>();",
            "        for (int i = 0; i < 100; i++) {",
            "            Random rnd = new Random(i);",
            "            colorCodes.put(",
            "                    i,",
            "                    String.format(",
            "                            \"\\\"#%2x%2x%2x\\\"\",",
            "                            rnd.nextInt(255), rnd.nextInt(255), rnd.nextInt(255)));",
            "        }",
            "        return colorCodes;",
            "    }"
