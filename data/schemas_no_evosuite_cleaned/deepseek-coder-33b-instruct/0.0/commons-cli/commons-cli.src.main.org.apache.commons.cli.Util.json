            "            return null;",
            "        }",
            "        if (str.startsWith(\"--\")) {",
            "            return str.substring(2);",
            "        }",
            "        if (str.startsWith(\"-\")) {",
            "            return str.substring(1);",
            "        }",
            "",
            "        return str;",
            "    }"
