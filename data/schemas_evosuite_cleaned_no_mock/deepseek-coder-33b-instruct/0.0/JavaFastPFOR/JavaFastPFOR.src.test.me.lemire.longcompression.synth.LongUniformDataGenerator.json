            "long[] generateUniformHash(int N, long Max) {",
            "                if (N > Max)",
            "                        throw new RuntimeException(\"not possible\");",
            "                long[] ans = new long[N];",
            "                Set<Long> s = new HashSet<>();",
            "                while (s.size() < N)",
            "                        s.add((long) (this.rand.nextDouble() * Max));",
            "                Iterator<Long> i = s.iterator();",
            "                for (int k = 0; k < N; ++k)",
            "                        ans[k] = i.next().longValue();",
            "                Arrays.sort(ans);",
            "                return ans;",
            "        }"
          ],
