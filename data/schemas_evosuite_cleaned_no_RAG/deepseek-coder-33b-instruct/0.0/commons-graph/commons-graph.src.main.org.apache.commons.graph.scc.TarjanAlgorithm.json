            "    @staticmethod",
            "    def __strongConnect(graph: \"DirectedGraph\", vertex: Set[V], verticesMetaInfo: Dict[Any, TarjanVertexMetaInfo], s: deque, stronglyConnectedComponent: Set[V], index: int) -> None:",
            "        from src.main.org.apache.commons.graph.DirectedGraph import DirectedGraph",
            "        from src.main.org.apache.commons.graph.scc.TarjanVertexMetaInfo import TarjanVertexMetaInfo",
            "        from src.main.java.org.jgrapht.graph import DirectedGraph",
            "        from src.main.java.org.jgrapht.alg.util import TarjanVertexWithLowNumber, StronglyConnectedComponents",
            "",
            "        vertex = TarjanVertexWithLowNumber(vertex)",
            "        graph = DirectedGraph()",
            "        strongly_connected_components = StronglyConnectedComponents(graph)",
            "        ",
            "        if vertex not in verticesMetaInfo:",
            "            verticesMetaInfo[vertex] = TarjanVertexWithLowNumber(index, None)",
            "            ",
            "        vertex.lowlink = index",
            "        index += 1",
            "        stack.append(vertex)",
            "",
            "        for successor in graph.getSuccessors(vertex):",
            "            if successor not in verticesMetaInfo:",
            "                strongly_connected_components.__strongConnect__(graph, successor, verticesMetaInfo, stack, stronglyConnectedComponent, index)",
            "                vertex.lowlink = min(vertex.lowlink, successor.lowlink)",
            "            elif successor in stack:",
            "                vertex.lowlink = min(vertex.lowlink, successor.index)",
            "",
            "        if vertex.lowlink == vertex.index:",
            "            strongly_connected_component = set()",
            "            while True:",
            "                w = stack.pop()",
            "                strongly_connected_component.add(w)",
            "                if w == vertex:",
            "                    break",
            "            stronglyConnectedComponent.append(strongly_connected_component)"
