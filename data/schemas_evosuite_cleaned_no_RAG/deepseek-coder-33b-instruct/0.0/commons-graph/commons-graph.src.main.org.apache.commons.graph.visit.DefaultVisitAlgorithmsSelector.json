          "translation": [
            "    def __applyingSearch(self, handler: \"GraphVisitHandler\", enqueue: bool) -> object:",
            "        from src.main.org.apache.commons.graph.VertexPair import VertexPair",
            "        visited_set = set()  # type: Set[Any]",
            "        vertex_deque = deque()  # type: deque[namedtuple('VertexPair', ['head', 'tail'])]",
            "        ",
            "        for vertex in self.__graph.getVertices():",
            "            if vertex not in visited_set:",
            "                handler.discoverVertex(vertex)",
            "                ",
            "                visited_set.add(vertex)",
            "                vertex_deque.append(VertexPair(None, vertex))",
            "                ",
            "                while len(vertex_deque) > 0:",
            "                    parent = vertex_deque[-1].head if enqueue else vertex_deque[0].tail",
            "                    current = vertex_deque[-1].tail if enqueue else vertex_deque[0].head",
            "                    ",
            "                    handler.examineVertex(current, parent)",
            "                    ",
            "                    for adjacent in self.__graph.getAdjacentVertices(current):",
            "                        if adjacent not in visited_set:",
            "                            handler.discoverVertex(adjacent)",
            "                            ",
            "                            visited_set.add(adjacent)",
            "                            vertex_deque.append(VertexPair(current, adjacent))",
            "                    ",
            "                    handler.finishVertex(vertex_deque[-1].tail if enqueue else vertex_deque[0].head)",
            "                    vertex_deque.pop() if enqueue else vertex_deque.popleft()",
            "        ",
            "        return None"
          ],
