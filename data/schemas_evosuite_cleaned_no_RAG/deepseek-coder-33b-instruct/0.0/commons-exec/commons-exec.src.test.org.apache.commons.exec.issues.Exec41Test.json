            "        from src.main.org.apache.commons.exec.CommandLine import CommandLine",
            "        from src.main.org.apache.commons.exec.ExecuteWatchdog import ExecuteWatchdog",
            "        from src.main.org.apache.commons.exec.DefaultExecutor import DefaultExecutor",
            "        cmdLine = None",
            "",
            "        if OS.isFamilyWindows():",
            "            cmdLine = CommandLine.parse0(\"ping.exe -n 10 -w 1000 127.0.0.1\")",
            "        elif \"HP-UX\" == os.getenv('os'):",
            "            cmdLine = CommandLine.parse0(\"ping 127.0.0.1 -n 10\")",
            "        elif OS.isFamilyUnix():",
            "            cmdLine = CommandLine.parse0(\"ping -c 10 127.0.0.1\")",
            "        else:",
            "            print(f\"The test 'testExec41WithStreams' does not support the following OS : {os.getenv('os')}\")",
            "            return",
            "",
            "        executor = DefaultExecutor.builder().get()",
            "        watchdog = ExecuteWatchdog.ExecuteWatchdog0(2 * 1000)",
            "        pumpStreamHandler = PumpStreamHandler.PumpStreamHandler2(sys.stdout, sys.stderr)",
            "        ",
