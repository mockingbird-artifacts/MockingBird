            "        assertEquals(\"9770264359008\", VALIDATOR.convertToEAN13(\"0264-3596\", \"00\"));",
            "        assertEquals(\"9771234567003\", VALIDATOR.convertToEAN13(\"1234-5679\", \"00\"));",
