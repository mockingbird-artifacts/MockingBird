          "translation": [
            "    def encode(self, source: object) -> str:",
            "        txt = str(source).lower()",
            "        if txt == \"\":",
            "            return self.__SIX_1",
            "        else:",
            "            txt = re.sub(r'([pt][^ao]|[aeiou])h$', r'\\1', txt)",
            "            txt = re.sub(r'(c)(?=ia)', 's', txt)",
            "            txt = re.sub('ph', 'f', txt)",
            "            txt = re.sub(r'([wy][^ao]|[aeiou])h$', r'\\1', txt)",
            "            txt = re.sub(r'(g)(y|h)[^aeiou]$', 'j', txt)",
            "            txt = re.sub(r'(gg)(y|h)[^aeiou]$', 'j', txt)",
            "            txt = re.sub(r'([csz])c', r'\\1s', txt)",
            "            txt = re.sub(r'([csz])x', r'\\1ks', txt)",
            "            txt = re.sub(r'(w)(?=[pt][^ao]|[aeiou])', '', txt)",
            "            txt = re.sub(r'(\\w)\\\\1{2,}', '', txt)",
            "            txt = re.sub('[aeiou]', '', txt)",
            "            txt = re.sub('([^\\s])\\1+', r'\\1', txt)",
            "            txt = re.sub(' ', '', txt)",
            "            return (StringBuilder(txt).append(\"111111\").toString()[:6])"
          ],
