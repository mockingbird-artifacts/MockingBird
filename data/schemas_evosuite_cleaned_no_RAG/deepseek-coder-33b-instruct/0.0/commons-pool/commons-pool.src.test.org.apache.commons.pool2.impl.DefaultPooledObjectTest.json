            "            randomTask = allocateAndDeallocateTask if random.random() < probabilityOfAllocationTask else getIdleTimeTask",
            "            futures.append(executor.submit(randomTask))",
            "        ",
            "        for future in as_completed(futures):",
            "            future.result()",
            "        ",
            "        self.assertFalse(negativeIdleTimeReturned.is_set(), \"DefaultPooledObject.getIdleTimeMillis() returned a negative value\")"
