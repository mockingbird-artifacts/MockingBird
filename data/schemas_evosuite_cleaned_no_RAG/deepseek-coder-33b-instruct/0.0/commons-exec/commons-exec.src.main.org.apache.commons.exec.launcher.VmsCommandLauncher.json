          "translation": [
            "    def __createCommandFile(self, cmd: \"CommandLine\", env: Dict[str, str]) -> Path:",
            "        from src.main.org.apache.commons.exec.util.StringUtils import StringUtils",
            "        command_file = tempfile.NamedTemporaryFile(delete=False)",
            "        try:",
            "            writer = io.TextIOWrapper(command_file, encoding='utf-8')",
            "            writer.write('#!/bin/sh\\n')",
            "            if cmd.__substituteAll:",
            "                for key in env.keys():",
            "                    value = StringUtils.replace(env[key], '\\\\', '\\\\\\\\').replace('\"', '\\\\\"')",
            "                    writer.write('export %s=\"%s\"\\n' % (StringUtils.replace(key, '\"', '\\\\\"'), value))",
            "            else:",
            "                for key in env.keys():",
            "                    if cmd.__substitutionsToMake.contains(key):",
            "                        value = StringUtils.replace(env[key], '\\\\', '\\\\\\\\').replace('\"', '\\\\\"')",
            "                        writer.write('export %s=\"%s\"\\n' % (StringUtils.replace(key, '\"', '\\\\\"'), value))",
            "            if cmd.__command != None:",
            "                command = StringUtils.replace(cmd.__command, '\"', '\\\\\"').replace('$', '\\\\$')",
            "                writer.write('exec %s\\n' % command)",
            "            else:",
            "                writer.write('exit 0\\n')",
            "        finally:",
            "            command_file.close()",
            "        os.chmod(command_file.name, stat.S_IRUSR | stat.S_IWUSR | stat.S_IXUSR)",
            "        return pathlib.Path(command_file.name)"
          ],
