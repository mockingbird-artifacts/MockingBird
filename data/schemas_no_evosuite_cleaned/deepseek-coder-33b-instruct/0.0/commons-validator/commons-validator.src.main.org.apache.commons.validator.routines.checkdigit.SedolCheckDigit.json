          "translation": [
            "    def  _calculateModulus(self, code: str, includesCheckDigit: bool) -> int:",
            "        total = 0",
            "        for i in range(len(code)):",
            "            lth = len(code) + (1 if not includesCheckDigit else 0)",
            "            leftPos = i + 1",
            "            rightPos = lth - i",
            "            charValue = self._toInt(code[i], leftPos, rightPos)",
            "            weighted_value = self._weightedValue(charValue, leftPos, rightPos)",
            "            if weighted_value is not None:  # Check if the return value is not None",
            "                total += weighted_value",
            "        if total == 0:",
            "            raise Exception(\"Invalid code, sum is zero\")",
            "        return total % self.__modulus"
          ],
